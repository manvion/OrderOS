{
  "name": "dinedirect",
  "version": "0.1.0",
  "private": true,
  "description": "DineDirect — direct ordering platform for restaurants",
  "workspaces": [
    "apps/api",
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "setup": "node scripts/setup.mjs",
    "dev:api": "npm run start:dev --workspace=@dinedirect/api",
    "dev:web": "npm run dev --workspace=@dinedirect/web",
    "build": "npm run build --workspace=@dinedirect/shared && npm run build --workspace=@dinedirect/api && npm run build --workspace=@dinedirect/web",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "smoke": "node scripts/smoke.mjs",
    "db:generate": "npm run db:generate --workspace=@dinedirect/api",
    "db:migrate": "npm run db:migrate --workspace=@dinedirect/api",
    "db:deploy": "npm run db:deploy --workspace=@dinedirect/api",
    "db:status": "npm run db:status --workspace=@dinedirect/api",
    "db:seed": "npm run db:seed --workspace=@dinedirect/api",
    "admin:create": "npm run admin:create --workspace=@dinedirect/api --",
    "db:studio": "npm run db:studio --workspace=@dinedirect/api",
    "infra:up": "docker compose up -d postgres redis",
    "infra:down": "docker compose down",
    "demo": "node scripts/demo/check-ports.mjs && npm-run-all --parallel demo:api demo:web demo:site",
    "demo:api": "node scripts/demo/mock-api.mjs",
    "demo:web": "npm run start --workspace=@dinedirect/web -- -p 3005",
    "demo:site": "npx --yes serve -l 8090 scripts/demo/site",
    "demo:build": "cd apps/web && next build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
