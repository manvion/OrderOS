# ==========================================================================
# DineDirect — environment
#
# Copy to .env and fill in. The API validates this on boot (apps/api/src/config/env.ts)
# and REFUSES TO START if anything required is missing — a bad config should
# crash at deploy, not at the first customer's checkout.
#
# Marked (required) = the app will not boot without it.
# Everything else degrades gracefully: unset Twilio and SMS is logged instead of
# sent; unset Uber and delivery dispatch is disabled; unset Azure and uploads go
# to local disk (dev only — this one IS required in production).
# ==========================================================================

# --- Core -----------------------------------------------------------------
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000

# The apex domain tenants live under: <slug>.dinedirect.manvion.ca
APP_DOMAIN=dinedirect.manvion.ca

# Extra origins allowed by CORS, comma-separated. Any *.APP_DOMAIN subdomain is
# allowed automatically — this is for the dashboard and local dev.
# Entries may carry ONE wildcard in a hostname label for Vercel preview deploys,
# which mint a new hostname per deploy:
#   https://dinedirect-*-yourteam.vercel.app
# The * matches one label's worth of deploy hash ([a-z0-9-]+), never dots — so a
# blanket *.vercel.app (every app Vercel hosts) cannot be expressed by accident.
CORS_ORIGINS=http://localhost:3000

# --- Database (required) --------------------------------------------------
DATABASE_URL=postgresql://dinedirect:dinedirect@localhost:5432/dinedirect

# --- Redis ----------------------------------------------------------------
# Menu cache, distributed locks, and the Uber Direct retry queue.
REDIS_URL=redis://localhost:6379

# --- Clerk (required) -----------------------------------------------------
# https://dashboard.clerk.com -> API keys
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

# --- Platform admins ------------------------------------------------------
# YOU. Comma-separated emails that become platform SUPER_ADMINs the first time
# they sign in. This is how /admin becomes reachable at all.
#
# LEAVE THIS UNSET AND NOBODY IS AN ADMIN. There is no other way in: bootstrapping
# by env rather than by an endpoint is deliberate, because a "create the first
# admin" API is a permanent backdoor. So an empty allowlist means /admin rejects
# every visitor, including you, forever.
#
# Must match the VERIFIED PRIMARY EMAIL on your Clerk account — the guard reads the
# email from Clerk, never from the request, so you cannot claim to be an admin by
# sending a header. Getting the address wrong here looks exactly like being
# rejected, because it is.
PLATFORM_ADMIN_EMAILS=you@yourcompany.com

# --- Stripe (required) ----------------------------------------------------
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx

# From `stripe listen --forward-to localhost:4000/api/payments/webhook`,
# or the endpoint's signing secret in the Stripe dashboard.
# The API rejects any webhook whose signature doesn't verify against this.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# Platform commission in basis points, taken as a Stripe application fee.
# 0 = you take nothing. 250 = 2.5%.
PLATFORM_FEE_BPS=0

# --- Uber Direct (optional) -----------------------------------------------
# https://developer.uber.com/docs/deliveries — leave unset and delivery dispatch
# is simply unavailable (restaurants can still self-deliver).
UBER_CLIENT_ID=
UBER_CLIENT_SECRET=
UBER_CUSTOMER_ID=
UBER_API_BASE_URL=https://api.uber.com
UBER_AUTH_URL=https://auth.uber.com/oauth/v2/token

# Shared secret Uber signs delivery webhooks with (HMAC-SHA256 over the raw body).
# Without it, ALL Uber webhooks are rejected — we will not accept unsigned
# delivery status updates.
UBER_WEBHOOK_SECRET=

# Testing with sandbox credentials above? Set this true or a dispatched delivery
# sits at "pending" forever -- sandbox has no real couriers to match against.
# This turns on Uber's own Robo Courier simulator instead. Turn back off (or
# unset) the moment UBER_CUSTOMER_ID etc. become production credentials.
UBER_SANDBOX_MODE=false

# --- Notifications (optional) ---------------------------------------------
# Unset -> messages are logged, not sent. Fine for local dev.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@dinedirect.manvion.ca

# --- Object storage: logos, menu photos, QR PNGs --------------------------
#
# ONE of the two blocks below is REQUIRED IN PRODUCTION. The app refuses to boot
# without either — writing customer logos to a container's ephemeral disk works
# perfectly right up until the redeploy that silently erases every image every
# restaurant ever uploaded. Unset in dev, uploads go to ./uploads. That's fine.
#
# --- Option A: S3-compatible (Cloudflare R2, AWS S3, Backblaze, MinIO) ----
# R2 is the easy answer: free to 10GB, no egress fees, two-minute signup.
#
#   Cloudflare -> R2 -> Create bucket
#   -> Manage R2 API Tokens -> Create token (Object Read & Write)
#   -> Bucket -> Settings -> Public access -> enable r2.dev subdomain
#
# S3_ENDPOINT is where we UPLOAD to. S3_PUBLIC_URL is where the world READS from.
# They are NOT the same URL, and conflating them is the classic R2 mistake: every
# upload reports success and every image 403s.
S3_ENDPOINT=            # https://<account-id>.r2.cloudflarestorage.com
S3_BUCKET=              # dinedirect-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto          # 'auto' is correct for R2
S3_PUBLIC_URL=          # https://pub-<hash>.r2.dev  (or your own CDN domain)

# --- Option B: Azure Blob -------------------------------------------------
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=dinedirect-media
AZURE_STORAGE_PUBLIC_URL=

# --- Embeddable widget ----------------------------------------------------
# The URL restaurants paste into their own websites. It is baked into the snippet
# the dashboard generates, so changing it does NOT update sites that already have
# the old one — treat it as permanent once a single restaurant has installed.
#
# Unset -> falls back to ${WEB_URL}/widget.js, which is what you want locally.
# In production point a CDN at the web app and set it to the CDN's URL.
WIDGET_CDN_URL=

# --- Custom domains (Vercel) ----------------------------------------------
# Restaurants bring their own domain (joesburgers.com). We do NOT sell domains —
# they buy it wherever they like, and we attach it to THIS ONE Vercel project and
# tell them which DNS records to add. There is no repo and no build per
# restaurant: one multi-tenant deployment serves every domain.
#
# Token needs the "domains" scope on the project. Unset -> the domain feature is
# disabled and the dashboard says so, rather than half-working.
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
# Only if the project lives under a team rather than a personal account. Wrong or
# missing team ID is the usual cause of a 403 from the Vercel API.
VERCEL_TEAM_ID=

# --- Geocoding (delivery radius) ------------------------------------------
# Turns a customer's address into lat/lng so we can refuse orders outside the
# delivery radius ("too far to deliver") BEFORE taking their money.
# Tried in order; each is optional. With none set we fall back to Nominatim,
# which is rate-limited and NOT acceptable for production traffic.
GOOGLE_MAPS_API_KEY=
MAPBOX_TOKEN=

# --- Menu import (photo -> menu) --------------------------------------------
# Claude reads a photographed menu into structured items the owner reviews and
# imports. Optional: unset, the dashboard hides the "Import from photo" button
# and menus are typed by hand. https://platform.claude.com -> API keys
ANTHROPIC_API_KEY=
# OpenRouter -- the FREE lane. With this set, menu import tries OpenRouter's free
# vision models first (Anthropic, if configured, is the quality backstop). Get a
# key at https://openrouter.ai/keys. Override the model ladder when the free
# catalog churns, comma-separated:
# OPENROUTER_MODELS=google/gemma-4-31b-it:free,nvidia/nemotron-nano-12b-v2-vl:free
OPENROUTER_API_KEY=

# --- Rate limiting --------------------------------------------------------
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=120

# --- Web (Next.js) --------------------------------------------------------
# NEXT_PUBLIC_* are inlined into the browser bundle at BUILD time. Changing them
# requires a rebuild, not just a restart.
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_DOMAIN=dinedirect.manvion.ca

# --- Live delivery map ----------------------------------------------------
# The map is fully open and key-free: MapLibre GL renders OpenStreetMap tiles from
# OpenFreeMap (no key, no limits), routing is OSRM, geocoding is Nominatim.
#
# ROUTING — where the road-following line from the driver to the door comes from.
# Unset = the free public OSRM demo server (fine for launch, but it rate-limits and
# times out, so routes often fall back to a straight line). For reliable routing,
# run the bundled self-hosted OSRM (infra/osrm) and point OSRM_URL at it:
#   - locally:  docker compose --profile full up  (OSRM_URL is preset to http://osrm:5000)
#   - hosted:   deploy infra/osrm as its own service and set OSRM_URL to its URL
OSRM_URL=
# MULTI-COUNTRY routing: one OSRM instance only knows the region it was built from, so
# run one per region and map each country you serve to the right one. JSON, keyed by
# country ISO code (several countries can share a continent instance). When set, it wins
# over OSRM_URL for a matching country; unmatched countries fall back to OSRM_URL.
#   OSRM_URLS={"CA":"http://osrm-na:5000","US":"http://osrm-na:5000","IN":"http://osrm-in:5000"}
OSRM_URLS=
# The regional OpenStreetMap extract the self-hosted OSRM preprocesses. Pick the
# SMALLEST region that covers where you deliver — smaller = less RAM/disk, faster build.
# e.g. https://download.geofabrik.de/north-america/canada/quebec-latest.osm.pbf
OSRM_PBF_URL=
# Fallback routing URL for the few map contexts that can't reach our API (no tenant
# slug). Normally leave unset — the map routes through our own cached OSRM_URL.
NEXT_PUBLIC_OSRM_URL=
