# Staff app configuration. Copy to `.env` and fill in.
# Both are PUBLIC values (baked into the app bundle) — safe, but keep .env out of git.

# The SAME Clerk publishable key your web app uses (Vercel → NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Your API's base URL — same value as the web app's NEXT_PUBLIC_API_URL.
# The origin only: no trailing /api, no trailing slash, must be https in production.
EXPO_PUBLIC_API_URL=https://api.dinedirect.manvion.ca
