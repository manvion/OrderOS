// DineDirect — multi-tenant restaurant ordering platform.
//
// TENANCY RULE: every table below except `User` (which is scoped by membership)
// and `WebhookEvent` (which is global) carries a `restaurantId`. Every query in
// the API goes through TenantContext, which injects that filter. There is no
// code path that reads tenant data without a restaurantId in the WHERE clause.
//
// MONEY RULE: all monetary amounts are integer cents (Int). No floats, ever.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum StaffRole {
  OWNER
  MANAGER
  STAFF
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY
  DRIVER_ASSIGNED
  OUT_FOR_DELIVERY
  DELIVERED
  COMPLETED
  CANCELLED
}

enum FulfillmentType {
  PICKUP
  DELIVERY
  DINE_IN
}

/// The language(s) a restaurant writes its content in. Drives the AI-fill controls:
/// a single language just writes in it; BOTH offers English / French / both.
enum MenuLanguage {
  EN
  FR
  BOTH
}

/// See Restaurant.websiteTemplate.
enum WebsiteTemplate {
  /// Full-bleed cover photo hero, gallery grid, a facts row, a closing pitch.
  /// Editorial and photo-forward -- the right choice when a restaurant has (or
  /// will get) real photography.
  CLASSIC
  /// Solid brand-colour hero, no photo dependency, menu-forward. Built for
  /// speed: a QR scan should land on "order now", not a magazine spread.
  BOLD
  /// Small centered logo/name, generous whitespace, plain text facts. No
  /// photography anywhere -- the right choice for a restaurant with none yet,
  /// rather than the CLASSIC hero's gradient-wash fallback standing in for one.
  MINIMAL
  /// Warm cream palette, rounded coupon-card sections, a dashed-border closing
  /// pitch. Playful and artisanal -- built for a place that wants to feel
  /// hand-made, not corporate.
  RUSTIC
  /// Bold black display type, a personal greeting, pill-shaped facts, a
  /// bright accent CTA with a prep-time badge. Built for speed and personality
  /// over photography -- the app-like choice.
  BUILDER
  /// Chunky rounded display type, bright color-blocked bento cards, a
  /// top-picks list. Playful and confident -- built for a place with a fun,
  /// youthful brand.
  BENTO
  /// Cream-and-forest-green palette, serif display type, a dark band behind
  /// the hero photo. Editorial and upscale -- the fine-dining choice.
  ELEGANT
  /// Dark charcoal + one bright accent colour, centered chunky headline, a
  /// phone-framed product photo, pill-shaped stat badges and CTAs
  /// everywhere. Confident comfort-food energy.
  PUNCHY
}

/// See Restaurant.logoDisplayMode.
enum LogoDisplayMode {
  LOGO_AND_NAME
  LOGO_ONLY
  NAME_ONLY
}

/// See Restaurant.themeMode.
enum ThemeMode {
  /// The template's bright, airy palette. Default for every template.
  LIGHT
  /// The template's inverted, moody palette -- same layout, same personality,
  /// flipped tone. Not a per-template redesign: backgrounds, cards and text
  /// swap through shared tokens (see .storefront-dark in globals.css) so
  /// every template, including future ones, gets it for free.
  DARK
}

/// How a restaurant is reached by customers.
///
/// WEBSITE  — the full storefront at <slug>.dinedirect.manvion.ca (or their own domain):
///            homepage, about page, menu, the lot. Their online presence.
///
/// QR_ONLY  — no website at all. The ONLY way in is scanning a QR code on the
///            table or the counter. Plenty of restaurants have a Facebook page and
///            no site, and do not want one; giving them a homepage they will never
///            link to is a page that ranks for their name and shows a half-finished
///            site. So in this mode the storefront root sends the customer straight
///            to the menu, the marketing pages are gone, and the whole thing is
///            noindexed — it isn't a website, it's an ordering terminal that lives
///            in the customer's pocket.
///
/// The widget (their existing site) is orthogonal: it is a WebsiteIntegration, and
/// a restaurant can run it alongside either mode.
enum OrderingMode {
  WEBSITE
  QR_ONLY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

/// How this order was actually paid. STRIPE is the online-checkout default; the
/// other two exist for a staff-entered walk-in or phone order where the customer
/// pays in person -- no Stripe charge ever happens, so there is no card/webhook
/// data to attach.
enum PaymentMethod {
  STRIPE
  CASH
  CARD_TERMINAL
}

enum DeliveryStatus {
  PENDING
  QUOTED
  CREATED
  PICKUP_ENROUTE
  DROPOFF_ENROUTE
  DELIVERED
  CANCELLED
  FAILED
}

enum QRCodeType {
  TABLE
  FLYER
  COUNTER
  /// Not an ordering code -- points at the public "now serving" board (see
  /// OrdersService.listStatusBoard) instead of the menu. For a TV by the
  /// counter, or a poster someone waiting on a pickup/dine-in order can scan.
  BOARD
}

/// Who actually carries the food. Decided PER ORDER, not once in settings — a
/// restaurant with its own driver still wants Uber as overflow on a busy Friday,
/// and one that normally uses Uber still wants to hand a nearby order to the kid
/// with the moped rather than pay a courier fee.
enum DeliveryProvider {
  UBER
  DOORDASH
  /// India intracity courier (Porter). Uber Direct / DoorDash Drive don't operate
  /// in India, so this is the auto-dispatch option there.
  PORTER
  SELF
}

enum SelectionType {
  SINGLE
  MULTIPLE
}

enum OnboardingStep {
  ACCOUNT
  BUSINESS_DETAILS
  BRANDING
  MENU
  PAYMENTS
  DELIVERY
  PUBLISHED
}

// ---------------------------------------------------------------------------
// Tenant root
// ---------------------------------------------------------------------------

model Restaurant {
  id   String @id @default(cuid())
  /// Subdomain: <slug>.dinedirect.manvion.ca. Immutable after publish (links would break).
  slug String @unique

  name        String
  description String?
  email       String
  phone       String

  // Address — denormalised because Uber Direct needs it on every pickup request
  // and we don't want a join in the delivery hot path.
  street     String
  city       String
  state      String
  postalCode String
  country    String  @default("US")
  latitude   Float?
  longitude  Float?

  timezone String @default("America/New_York")
  currency String @default("USD")

  /**
   * Who the restaurant is to a tax authority, as opposed to who it is to a customer.
   *
   * `legalName` is the entity that issues the invoice ("1187456 Ontario Inc."), which
   * is very often not the name on the awning ("Bella Burger"). A receipt must carry
   * the legal entity, not the brand.
   *
   * `taxId` is whatever that country calls it — GSTIN in India, GST/HST number in
   * Canada, VAT number in the UK, ABN in Australia. See packages/shared/src/countries.ts
   * for the shape and, more importantly, for whether a receipt is even VALID without
   * it: in Canada, India, the UK and Australia it is not.
   *
   * `businessNumber` is the company registration number, where it differs from the tax
   * number. Never printed — it exists because accountants ask for it.
   *
   * All nullable: restaurants below a registration threshold genuinely have no number,
   * and every restaurant that signed up before this existed has none either.
   */
  legalName      String?
  taxId          String?
  businessNumber String?

  // Branding
  logoUrl           String?
  coverImageUrl     String?
  brandPrimaryColor String  @default("#EA580C")
  brandAccentColor  String  @default("#0F172A")
  /// Three genuinely different storefront LAYOUTS, not a palette swap -- see
  /// apps/web/src/app/s/[slug]/page.tsx, which branches its entire JSX tree on
  /// this rather than reusing one template with theme variables.
  websiteTemplate   WebsiteTemplate @default(CLASSIC)
  /// Picked alongside the template, not by the customer on the live site --
  /// see the ThemeMode enum's comment.
  themeMode         ThemeMode @default(LIGHT)
  /// A logo that already has the restaurant's name baked into the artwork reads
  /// as a typo the moment the text name repeats right next to it. LOGO_ONLY and
  /// NAME_ONLY exist so the header shows exactly one, not always both.
  logoDisplayMode   LogoDisplayMode @default(LOGO_AND_NAME)
  /// How large the logo renders in the header, as a percentage of the default size.
  /// Lets a wide wordmark logo ("logo + name" baked into one image) be shown big
  /// instead of being capped small. 100 = default; clamped 50–250 by the API.
  logoScale         Int             @default(100)
  /// Show a soft, brand-coloured backdrop behind the header logo. Off by default;
  /// helps a transparent-PNG logo sit on a subtle tinted panel instead of bare.
  logoBackdrop      Boolean         @default(false)
  /// How the restaurant's NAME is styled in the header wordmark (when shown as text,
  /// not baked into a logo image). nameFont picks a type feel (DISPLAY/SERIF/SANS/
  /// MONO/SCRIPT); nameColor is null=default text, "BRAND", or a #hex; nameTransform
  /// is NONE or UPPERCASE. Plain strings, not enums, so adding a face later needs no
  /// migration — the web layer maps unknown values back to the default.
  nameFont          String          @default("DISPLAY")
  nameColor         String?
  nameTransform     String          @default("NONE")
  /// The restaurant's own social profiles, shown as an icon row on the storefront.
  /// Array of { platform, url } — see socialLinksSchema in packages/shared. JSON so
  /// adding a platform never needs a migration.
  socialLinks       Json?
  /// Which language(s) this restaurant writes menu & catering content in. Drives
  /// the AI-fill language options: a single language writes in it; BOTH offers a
  /// French / English / both choice.
  menuLanguage      MenuLanguage    @default(EN)

  /// Their About page, in their own words.
  ///
  /// PLAIN TEXT, not HTML or markdown, and it is rendered as escaped paragraphs.
  /// Letting a tenant store HTML that we then inject into a page served on
  /// *.dinedirect.manvion.ca is stored XSS with extra steps — one restaurant could run script
  /// on another's domain, or on ours. Blank lines separate paragraphs. That is the
  /// whole formatting model, and it is enough for "we opened in 1998".
  aboutHeadline String?
  aboutBody     String? @db.Text
  /// French versions of the About headline/story for a bilingual storefront —
  /// typed by the restaurant; null falls back to the default-language version.
  aboutHeadlineFr String?
  aboutBodyFr     String? @db.Text

  /// BusinessHours JSON — see packages/shared/src/hours.ts for the shape.
  businessHours Json

  /// How customers reach this restaurant. See the OrderingMode enum.
  orderingMode OrderingMode @default(WEBSITE)

  // Fulfillment configuration
  pickupEnabled           Boolean @default(true)
  deliveryEnabled         Boolean @default(false)
  dineInEnabled           Boolean @default(false)
  scheduledOrdersEnabled  Boolean @default(false)
  /// We can dispatch an Uber courier.
  uberDirectEnabled       Boolean @default(false)
  /// We can dispatch a DoorDash Drive courier.
  ///
  /// Independent of uberDirectEnabled, and both can be on at once. When they are,
  /// we quote BOTH and dispatch the cheaper one — which is the whole point of
  /// running two couriers, and is worth real money on every single order.
  doorDashEnabled         Boolean @default(false)
  /// The restaurant has their own driver.
  ///
  /// If BOTH this and uberDirectEnabled are on, the dashboard asks per order
  /// rather than guessing — which is right, because the answer genuinely depends
  /// on how far away the customer is and whether the moped kid is on shift.
  selfDeliveryEnabled     Boolean @default(false)
  /// Dispatch a Porter courier (India). The India-market counterpart to Uber
  /// Direct / DoorDash Drive, which don't operate there. See paymentProviderForCountry.
  porterEnabled           Boolean @default(false)
  deliveryFeeCents        Int     @default(499)
  deliveryRadiusMeters    Int     @default(8000)
  minOrderCents           Int     @default(0)
  serviceFeeCents         Int     @default(0)
  /// Effective combined rate, derived from taxComponents. Kept for quick display
  /// and for the simple single-rate case.
  taxRateBps              Int     @default(0)

  /**
   * Named tax components: [{ name: "GST", rateBps: 500 }, { name: "QST", rateBps: 998 }].
   *
   * A single rate cannot express Quebec (GST + QST) or India (CGST + SGST), and
   * both jurisdictions require the components to be NAMED SEPARATELY on the
   * receipt. See packages/shared/src/tax.ts.
   */
  taxComponents           Json?
  /// 'US' | 'CA' | 'IN'. Which tax regime this restaurant is under.
  taxCountry              String?
  /// State / province, used to resolve the default rates.
  taxRegion               String?
  prepTimeMinutes         Int     @default(20)

  // Stripe Connect — each restaurant is paid directly; we never hold their funds.
  stripeAccountId       String?
  stripeChargesEnabled  Boolean @default(false)
  stripePayoutsEnabled  Boolean @default(false)

  // Razorpay Route — the India equivalent of Stripe Connect. An Indian restaurant
  // (see paymentProviderForCountry) collects UPI/cards through Razorpay, which splits
  // each payment to this linked account while we keep our commission. Null/false
  // until the restaurant has completed Razorpay's KYC onboarding.
  razorpayAccountId     String?
  razorpayEnabled       Boolean @default(false)
  /// Platform commission in basis points, taken as a Stripe application fee.
  ///
  /// The EFFECTIVE rate. Normally derived from `planTier` (see plans.ts), but a
  /// platform SUPER_ADMIN can override it per restaurant for a negotiated deal; when
  /// they do, `commissionOverridden` is set so a later plan change doesn't quietly
  /// reset the number we shook hands on.
  platformFeeBps        Int     @default(0)
  commissionOverridden  Boolean @default(false)

  // --- SaaS subscription -----------------------------------------------------
  //
  // The plan the restaurant is on. This is SEPARATE from Stripe Connect above:
  // Connect is how the restaurant gets PAID by its customers; the fields here are
  // how the restaurant PAYS US for the software, billed on the platform's own
  // Stripe account (Stripe Billing), not on their connected account.
  /// Which tier they're on. Everyone starts on the free STARTER tier.
  planTier              PlanTier           @default(STARTER)
  /// ACTIVE/TRIALING = features on. PAST_DUE = grace period. CANCELED = back to Starter.
  subscriptionStatus    SubscriptionStatus @default(ACTIVE)
  /// Null on the free tier. MONTHLY or ANNUAL once they pay.
  billingInterval       BillingInterval?
  /// Their customer + subscription on the PLATFORM's Stripe account. Unique: the
  /// billing webhook finds the restaurant BY these ids, so each maps to one tenant.
  stripeCustomerId       String? @unique
  stripeSubscriptionId   String? @unique
  /// When the current paid period ends — what we honour features until, and what
  /// the billing page shows as "renews on". Null on the free tier.
  planCurrentPeriodEnd   DateTime?

  // Lifecycle
  onboardingStep OnboardingStep @default(ACCOUNT)
  isPublished    Boolean        @default(false)
  publishedAt    DateTime?
  isActive       Boolean        @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Where the restaurant itself wants to be told about orders. Distinct from
  // `phone`/`email` (which are public, shown to customers): the number that gets
  // woken up at 8pm is the pass phone, not the one on the website.
  notifyPhone        String?
  notifyEmail        String?
  notifySmsEnabled   Boolean @default(true)
  notifyEmailEnabled Boolean @default(true)

  /// Off by default -- an existing restaurant shouldn't wake up to a program
  /// it never turned on. Rate is points credited per whole dollar of
  /// subtotal (pre-tax, pre-tip) on a paid order.
  loyaltyEnabled         Boolean @default(false)
  loyaltyPointsPerDollar Int     @default(1)

  /// Table reservations. "Simple capacity per slot": the restaurant sets how many
  /// bookings it will take for any one time slot, the slot length, and the booking
  /// window; availability is that capacity minus the live bookings in a slot. Off by
  /// default — a restaurant that doesn't take bookings must not appear to.
  reservationsEnabled        Boolean @default(false)
  /// Max bookings accepted for a single time slot. 0 with reservations on means
  /// "unlimited" would be wrong, so the API treats 0 as "not configured" → unavailable.
  reservationCapacityPerSlot Int     @default(0)
  /// Slot granularity in minutes (e.g. 30 → 6:00, 6:30, 7:00…). Derived from hours.
  reservationSlotMinutes     Int     @default(30)
  /// Largest party a customer can book online; bigger groups are told to call.
  reservationMaxPartySize    Int     @default(10)
  /// Minimum notice, in hours — a table at 7pm can't be booked at 6:59.
  reservationLeadHours       Int     @default(2)
  /// How many days ahead the calendar opens.
  reservationWindowDays      Int     @default(30)

  users      User[]
  customers  Customer[]
  categories Category[]
  products   Product[]
  modifierGroups ModifierGroup[]
  orders     Order[]
  payments   Payment[]
  deliveries Delivery[]
  qrCodes    QRCode[]
  auditLogs  AuditLog[]
  websiteIntegrations WebsiteIntegration[]
  widgetEvents        WidgetEvent[]
  staffInvites        StaffInvite[]
  notifications       NotificationLog[]
  customDomains       CustomDomain[]
  galleryImages       GalleryImage[]
  promotions          Promotion[]
  shifts              Shift[]
  cateringPackages    CateringPackage[]
  cateringRequests    CateringRequest[]
  reservations        Reservation[]

  @@index([isPublished, isActive])
  @@map("restaurants")
}

/// SaaS subscription tier. The definitions (price, limits, what each unlocks) live
/// in packages/shared/src/plans.ts — this enum is only the identity.
enum PlanTier {
  STARTER
  GROWTH
  PRO
}

enum BillingInterval {
  MONTHLY
  ANNUAL
}

/// Mirrors Stripe's subscription lifecycle, collapsed to the states we act on.
enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

/// Where a demo/"build it for me" request is in our follow-up pipeline.
enum DemoRequestStatus {
  NEW
  CONTACTED
  SCHEDULED
  WON
  LOST
}

/// A "Book a demo" / done-for-you setup lead from the marketing site.
///
/// This is NOT a tenant — nobody has signed up yet. It's an inbound lead the
/// platform follows up on (and, for the concierge "we build your site" offer,
/// quotes a one-time setup fee for). Deliberately its own table so a stranger
/// filling in a form can never touch anything a real restaurant owns.
model DemoRequest {
  id             String            @id @default(cuid())
  name           String
  email          String
  phone          String?
  restaurantName String?
  city           String?
  /// What they said they want — free text from the form.
  message        String?
  /// Which plan or offer they clicked from, if any (e.g. "GROWTH", "concierge").
  interest       String?
  status         DemoRequestStatus @default(NEW)
  /// The platform admin who picked it up, and when. Not a FK — admins are a small
  /// separate table and we only need the id for display.
  handledByAdmin String?
  handledAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status, createdAt])
  @@map("demo_requests")
}

/// PERCENT: `value` is basis points (500 = 5%). FIXED: `value` is cents off.
enum PromotionType {
  PERCENT
  FIXED
}

/// A discount a restaurant runs on its own storefront -- "10% off", "$5 off
/// orders over $30", a code for regulars, a weekend deal. Resolved server-side
/// at order-creation time (see OrdersService), never trusted from the client.
///
/// `code` null means it applies automatically to every qualifying order; set,
/// it means a customer must type it in at checkout. The unique constraint only
/// bites when a code is set -- Postgres treats each NULL as distinct, so any
/// number of auto-apply promotions can coexist.
model Promotion {
  id           String   @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  name  String
  type  PromotionType
  value Int

  code String?

  /// Empty = applies to the whole order (the original behaviour). Non-empty =
  /// only these specific products are discounted -- and only these products
  /// carry the "on promo" tag on the storefront menu. A restaurant running
  /// "10% off this burger" needs the tag on the burger, not an invisible
  /// discount nobody sees until checkout.
  productIds String[] @default([])

  minSubtotalCents Int       @default(0)
  startsAt         DateTime?
  endsAt           DateTime?
  isActive         Boolean   @default(true)

  /// How many orders have used this. Denormalised so the dashboard doesn't
  /// scan orders to show it.
  redemptions Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, code])
  @@index([restaurantId, isActive])
  @@map("promotions")
}

/// A photo on the restaurant's About page.
///
/// A separate table rather than a JSON array on Restaurant, because each image has a
/// storage key that must be deleted from blob storage when the row goes — and an
/// orphaned blob nobody can find is a bill that grows forever.
model GalleryImage {
  id String @id @default(cuid())

  url String
  /// The blob key, so deleting the row can delete the file.
  storageKey String
  caption    String?
  sortOrder  Int     @default(0)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([restaurantId, sortOrder])
  @@map("gallery_images")
}

// ---------------------------------------------------------------------------
// Custom domains
// ---------------------------------------------------------------------------

enum DomainStatus {
  /// Added, but their DNS doesn't point at us yet. We show them the records to add.
  PENDING_DNS
  /// DNS looks right; Vercel is issuing the certificate. Usually under a minute.
  ISSUING_CERT
  /// Live. The storefront serves on this domain over HTTPS.
  ACTIVE
  /// Something is wrong and needs the owner to act. `error` says what.
  FAILED
}

/**
 * A restaurant's own domain — joesburgers.com — pointing at their storefront.
 *
 * ARCHITECTURE NOTE, because this is the decision that saves the most money and
 * pain:
 *
 * We do NOT generate a repository per restaurant and deploy each one. The
 * storefront is already multi-tenant: ONE Vercel deployment serves every
 * restaurant, resolved by hostname. Attaching a custom domain is therefore a DNS +
 * certificate operation, not a build.
 *
 * A repo-per-restaurant design would mean a thousand git repos, a thousand builds,
 * a thousand things to keep patched, and a security fix that has to be rolled out a
 * thousand times. This way, a fix ships once and every restaurant has it.
 *
 * The domain is added to the Vercel project via their API, Vercel issues the
 * certificate, and the middleware maps the incoming Host back to the tenant.
 */
model CustomDomain {
  id String @id @default(cuid())

  /// Bare host, lowercased: "joesburgers.com" or "order.joesburgers.com".
  domain String @unique

  status DomainStatus @default(PENDING_DNS)

  /// The exact DNS records the owner must create. Rendered verbatim in the UI —
  /// Vercel tells us what it wants, and we do not paraphrase it.
  dnsRecords Json?

  /// Whatever went wrong, in the owner's language, not Vercel's.
  error String?

  /// Vercel has the domain attached to the project.
  vercelConfigured Boolean @default(false)
  /// Certificate issued and serving.
  sslActive Boolean @default(false)
  /// Registered with Stripe so Apple Pay renders. Silently absent otherwise.
  applePayRegistered Boolean @default(false)

  /// The verification cron backs off as attempts pile up; this bounds it.
  checkAttempts Int       @default(0)
  lastCheckedAt DateTime?
  verifiedAt    DateTime?

  /// Serve the storefront at this domain instead of <slug>.dinedirect.manvion.ca.
  isPrimary Boolean @default(true)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId])
  @@index([status])
  @@map("custom_domains")
}

// ---------------------------------------------------------------------------
// Platform operators (us, not the restaurants)
// ---------------------------------------------------------------------------

enum PlatformRole {
  /// Everything: commission, suspension, deleting a tenant.
  SUPER_ADMIN
  /// Read + act-as, for helping a stuck owner. Cannot change money or suspend.
  SUPPORT
}

/**
 * A member of OUR staff. Deliberately a separate table from `User`.
 *
 * `User` is a MEMBERSHIP: it binds a Clerk identity to exactly one restaurant, and
 * every tenant-scoped query hangs off it. If platform admins were just Users with a
 * special role, then "is this person allowed to see this restaurant's orders?" and
 * "is this person an employee of ours?" would be the same question — and the day
 * someone fat-fingers a role, a line cook becomes a platform operator.
 *
 * Keeping them separate means the tenant guard can stay brutally simple (no
 * membership, no access, no exceptions) and platform access is a deliberate,
 * separately-audited second door.
 */
model PlatformAdmin {
  id          String @id @default(cuid())
  clerkUserId String @unique
  email       String @unique

  name String?
  role PlatformRole @default(SUPPORT)

  isActive Boolean @default(true)

  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([clerkUserId])
  @@map("platform_admins")
}

/**
 * A platform admin acting inside a restaurant's dashboard to help them.
 *
 * Support access is a loaded gun: it lets one of our employees read a restaurant's
 * customers, orders and revenue. So every session is opened explicitly, carries a
 * reason, expires on its own, and is written down. "We looked at your data because
 * you asked us to, here is exactly when and why" is the only defensible answer when
 * a restaurant asks.
 */
model SupportSession {
  id String @id @default(cuid())

  adminId      String
  adminEmail   String
  restaurantId String

  /// Free text, required. "Owner can't publish — ticket #412".
  reason String

  /// Short-lived by construction. An admin who forgets to close a session does not
  /// keep standing access to a restaurant's data.
  expiresAt DateTime
  endedAt   DateTime?

  createdAt DateTime @default(now())

  @@index([restaurantId, createdAt])
  @@index([adminId, createdAt])
  @@map("support_sessions")
}

// ---------------------------------------------------------------------------
// Identity
// ---------------------------------------------------------------------------

/// Restaurant staff. Authenticated by Clerk; `clerkUserId` is the join key.
/// A person who works at two restaurants has two User rows (one per tenant).
model User {
  id          String @id @default(cuid())
  clerkUserId String

  email     String
  firstName String?
  lastName  String?
  imageUrl  String?

  role   StaffRole @default(STAFF)
  isActive Boolean @default(true)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs AuditLog[]
  shifts    Shift[]

  /// One membership per person per restaurant.
  @@unique([clerkUserId, restaurantId])
  @@index([restaurantId])
  @@index([clerkUserId])
  @@map("users")
}

/// A scheduled block of time for one staff member. Nothing more than that --
/// no clock-in/out, no timesheet math. A manager plans who's working when;
/// staff see their own upcoming shifts.
model Shift {
  id String @id @default(cuid())

  startsAt DateTime
  endsAt   DateTime
  note     String?

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId, startsAt])
  @@index([userId, startsAt])
  @@map("shifts")
}

/// A guest who ordered. Not a Clerk account — identified by phone within a
/// tenant, so repeat orders from the same number roll up to one customer record.
model Customer {
  id    String  @id @default(cuid())
  name  String
  phone String
  email String?

  /**
   * Set when the customer has an account. NULL for guests.
   *
   * Guest checkout is not a fallback, it is the default: forcing a signup before
   * someone can buy a burger is the fastest way to lose the sale. An account is a
   * convenience we offer AFTER they've ordered ("save this address for next time"),
   * never a toll gate before it.
   *
   * A guest who later signs up with the same phone number gets their history
   * claimed automatically — the Customer row already exists, we just attach an
   * identity to it.
   */
  clerkUserId String?

  // Rolling aggregates, updated when an order reaches COMPLETED. Denormalised so
  // the customers dashboard doesn't aggregate the whole orders table per row.
  totalOrders     Int      @default(0)
  totalSpentCents Int      @default(0)
  lastOrderAt     DateTime?

  /// Only meaningful while Restaurant.loyaltyEnabled is on. Credited when a
  /// paid order lands, clawed back if that order is later cancelled/refunded
  /// in full -- see applyInventoryDelta's sibling, applyLoyaltyDelta.
  loyaltyPoints Int @default(0)

  /// Marketing consent for SMS. Transactional order SMS does not require this.
  marketingOptIn Boolean @default(false)

  /// Set when the customer replies STOP. Once true we send them NOTHING by SMS,
  /// including transactional order updates — US carriers and the TCPA treat a STOP
  /// as absolute, and honouring it only for marketing is how a number gets blocked.
  /// They still get email, and the tracking link still works.
  smsOptOut   Boolean   @default(false)
  smsOptOutAt DateTime?

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  addresses CustomerAddress[]

  @@unique([restaurantId, phone])
  /// One customer record per account per restaurant.
  @@unique([restaurantId, clerkUserId])
  @@index([restaurantId, lastOrderAt])
  @@index([clerkUserId])
  @@map("customers")
}

/// A saved delivery address. The entire reason to have an account: never type
/// your address again.
model CustomerAddress {
  id String @id @default(cuid())

  /// "Home", "Work". Free text — people's mental models of their own addresses
  /// are not ours to constrain.
  label String?

  street     String
  city       String
  state      String
  postalCode String
  country    String @default("US")
  latitude   Float?
  longitude  Float?

  /// Buzzer codes, gate instructions, "leave with the neighbour". The stuff that
  /// actually determines whether a delivery succeeds.
  notes String?

  isDefault Boolean @default(false)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@map("customer_addresses")
}

// ---------------------------------------------------------------------------
// Menu
// ---------------------------------------------------------------------------

model Category {
  id          String  @id @default(cuid())
  name        String
  /// French translation of the name, for a bilingual (BOTH) storefront. Auto-filled
  /// by AI and editable; null falls back to `name`.
  nameFr      String?
  description String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@index([restaurantId, sortOrder])
  @@map("categories")
}

model Product {
  id          String  @id @default(cuid())
  name        String
  /// French translations for a bilingual (BOTH) storefront — auto-filled by AI when
  /// the item is saved, editable, and null-falls-back to the default language.
  nameFr        String?
  description String?
  descriptionFr String?
  priceCents  Int
  imageUrl    String?
  sortOrder   Int     @default(0)

  /// Owner toggles this when they run out. Hidden from the storefront, but
  /// historical order items still reference the product.
  isAvailable Boolean @default(true)

  /// Opt-in per product -- most menu items (a dish made to order) have no
  /// meaningful "stock count". Only products with a real finite count
  /// (a limited-batch dessert, a case of a specific bottled drink) turn this on.
  trackInventory Boolean @default(false)
  /// Only meaningful when trackInventory is true. Decremented when an order
  /// is paid, restored when a paid order is cancelled; never read otherwise.
  stockQuantity  Int     @default(0)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  modifierGroups ModifierGroup[]
  orderItems     OrderItem[]

  @@index([restaurantId, categoryId, sortOrder])
  @@index([categoryId])
  @@map("products")
}

/// A set of choices attached to a product, e.g. "Size" (SINGLE) or "Extras"
/// (MULTIPLE). Owned by exactly one product — duplicating a group across
/// products is a copy, which keeps edits from leaking between menu items.
model ModifierGroup {
  id            String        @id @default(cuid())
  name          String
  selectionType SelectionType @default(SINGLE)
  required      Boolean       @default(false)
  minSelections Int           @default(0)
  maxSelections Int           @default(1)
  sortOrder     Int           @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  modifiers Modifier[]

  @@index([productId, sortOrder])
  @@map("modifier_groups")
}

model Modifier {
  id          String  @id @default(cuid())
  name        String
  /// Surcharge for this choice. 0 for "Small", 200 for "Large", etc.
  priceCents  Int     @default(0)
  isAvailable Boolean @default(true)
  sortOrder   Int     @default(0)

  modifierGroupId String
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItemModifiers OrderItemModifier[]

  @@index([modifierGroupId, sortOrder])
  @@map("modifiers")
}

// ---------------------------------------------------------------------------
// Orders
// ---------------------------------------------------------------------------

model Order {
  id String @id @default(cuid())
  /// Human-readable, unique per restaurant. What staff shout across the kitchen.
  orderNumber String

  status      OrderStatus     @default(PENDING)
  fulfillment FulfillmentType

  // Money — every figure the customer was shown is frozen here at checkout so a
  // later menu price change can never alter a historical order's total.
  subtotalCents    Int
  taxCents         Int
  deliveryFeeCents Int @default(0)
  serviceFeeCents  Int @default(0)
  tipCents         Int @default(0)
  discountCents    Int @default(0)
  /// Which Promotion produced discountCents, if any. Not a relation FK -- a
  /// promotion can be edited or deleted later and the order's frozen discount
  /// must still make sense on its own.
  promotionId      String?
  totalCents       Int
  currency         String @default("USD")

  /// Snapshot of the tax rate used, so a rate change doesn't make old orders unreproducible.
  taxRateBps Int @default(0)

  /// Tax exactly as it was charged and printed: [{ name, rateBps, amountCents }].
  /// Frozen at checkout — a rate change must never rewrite a historical receipt,
  /// and a tax audit reads THIS, not today's settings.
  taxLines   Json?

  /// Frozen at order time even though it's only credited to the customer once
  /// PAID -- a later change to loyaltyPointsPerDollar must not reprice what
  /// this order already promised.
  loyaltyPointsEarned Int @default(0)

  // Contact — captured on the order itself, not only on Customer, because a
  // customer may edit their profile later and the order must stay as-placed.
  customerName  String
  customerPhone String
  customerEmail String
  /// The language the customer ordered in ("en" / "fr"), captured from the
  /// storefront at checkout so their texts and emails come back in that language.
  /// Null for orders placed before this existed, or by a single-language storefront.
  locale        String?

  // Delivery destination
  deliveryStreet     String?
  deliveryCity       String?
  deliveryState      String?
  deliveryPostalCode String?
  deliveryCountry    String?
  deliveryLatitude   Float?
  deliveryLongitude  Float?
  deliveryNotes      String?

  notes       String?
  tableNumber String?

  /**
   * The code that gets the right food to the right person. EVERY order has one.
   *
   * Pickup: the customer reads it out at the counter. Dine-in: it's on the ticket
   * next to the table. Delivery: the courier reads it off their phone and staff
   * match it to the bag.
   *
   * Deliberately not the order number — sequential numbers look identical at a
   * glance on a bag label (0712-014 vs 0712-041). See packages/shared/src/handoff.ts.
   */
  handoffCode String?

  /// Null = ASAP. Set = customer picked a future slot.
  scheduledFor DateTime?

  acceptedAt  DateTime?
  readyAt     DateTime?
  completedAt DateTime?
  cancelledAt DateTime?

  /// Set the moment the kitchen accepts, defaulted from the restaurant's
  /// prep time scaled by how many items are actually in the order -- not
  /// the same guess for a 1-item order and a 12-item one. Kitchen staff can
  /// override it from the Kitchen board when they know better than the
  /// default. Powers the countdown on the public status board.
  estimatedReadyAt DateTime?
  cancelReason String?

  /// Public tracking token — the /track/:token URL is unguessable, so a customer
  /// can follow their order without an account and without exposing the order id.
  trackingToken String @unique @default(cuid())

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  qrCodeId String?
  qrCode   QRCode? @relation(fields: [qrCodeId], references: [id], onDelete: SetNull)

  /// Set when the order came through an embedded widget on the restaurant's own
  /// website. This is what makes "revenue by website" answerable — without it we
  /// could count widget orders but never attribute them to a domain.
  websiteIntegrationId String?
  websiteIntegration   WebsiteIntegration? @relation(fields: [websiteIntegrationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items    OrderItem[]
  payment  Payment?
  delivery Delivery?
  events   OrderEvent[]

  @@unique([restaurantId, orderNumber])
  @@index([restaurantId, status, createdAt])
  @@index([restaurantId, createdAt])
  @@index([customerId])
  /// Widget analytics groups orders by integration to compute revenue per website.
  @@index([websiteIntegrationId])
  @@map("orders")
}

/// A line item, price-frozen at checkout. `productId` is kept for analytics but
/// `name`/`unitPriceCents` are snapshots — renaming a product does not rewrite
/// history.
model OrderItem {
  id       String @id @default(cuid())
  name     String
  quantity Int

  /// Base product price at time of order.
  unitPriceCents Int
  /// unitPrice + modifiers, times quantity. Denormalised to keep receipts cheap.
  totalCents     Int

  notes String?

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  modifiers OrderItemModifier[]

  @@index([orderId])
  @@map("order_items")
}

model OrderItemModifier {
  id         String @id @default(cuid())
  name       String
  priceCents Int
  quantity   Int    @default(1)

  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  modifierId String?
  modifier   Modifier? @relation(fields: [modifierId], references: [id], onDelete: SetNull)

  @@index([orderItemId])
  @@map("order_item_modifiers")
}

/// Append-only status history. Powers the customer tracking timeline and gives
/// support a defensible record of who moved an order and when.
model OrderEvent {
  id     String      @id @default(cuid())
  status OrderStatus
  note   String?
  /// "system" | "restaurant" | "customer" | "uber" | "stripe"
  source String      @default("system")

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
  @@map("order_events")
}

// ---------------------------------------------------------------------------
// Payments
// ---------------------------------------------------------------------------

model Payment {
  id     String        @id @default(cuid())
  status PaymentStatus @default(PENDING)
  method PaymentMethod @default(STRIPE)

  amountCents         Int
  refundedAmountCents Int    @default(0)
  currency            String @default("USD")

  /// Application fee taken by the platform on this charge.
  platformFeeCents Int @default(0)

  /**
   * What a courier quoted for THIS order at the moment it was placed, recouped
   * from the restaurant inside the same Stripe charge (added to the application
   * fee). NULL means no courier was involved -- pickup, dine-in, self-delivery --
   * or no quote could be had, in which case the platform absorbs the dispatch
   * cost rather than blocking a paying customer.
   *
   * The checkout-time quote, not the dispatch-time price: the application fee is
   * fixed when the card is charged, and dispatch re-quotes minutes later. The
   * deltas are cents in either direction and average out; the alternative --
   * settling exact costs after the fact -- is an invoicing system.
   */
  courierCostCents Int?

  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String? @unique
  stripeChargeId          String?
  /// Razorpay refs for India orders (see paymentProviderForCountry). The payment id
  /// is what a refund is issued against, the order id is what Checkout was opened with.
  razorpayOrderId         String? @unique
  razorpayPaymentId       String? @unique
  /// Card brand + last4, for the dashboard. Never store a PAN.
  cardBrand String?
  cardLast4 String?

  failureReason String?
  paidAt        DateTime?
  refundedAt    DateTime?

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refunds Refund[]

  @@index([restaurantId, status])
  @@map("payments")
}

model Refund {
  id             String @id @default(cuid())
  amountCents    Int
  reason         String?
  stripeRefundId String @unique

  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  /// Clerk user id of the staff member who issued it. Null = issued by Stripe/system.
  issuedByUserId String?

  createdAt DateTime @default(now())

  @@index([paymentId])
  @@map("refunds")
}

// ---------------------------------------------------------------------------
// Delivery (Uber Direct)
// ---------------------------------------------------------------------------

model Delivery {
  id     String         @id @default(cuid())
  status DeliveryStatus @default(PENDING)

  /// UBER / DOORDASH = a courier we dispatched. SELF = the restaurant's own driver.
  ///
  /// This is the field that says which API the identifiers below belong to, and which
  /// client can cancel or track the delivery. Read it before you touch them.
  provider DeliveryProvider @default(UBER)

  // The restaurant's own driver. Only set when provider = SELF. Kept here rather
  // than in a Driver table on purpose: most self-delivering restaurants have one
  // or two people and a phone number, not a fleet to manage. Model the fleet when
  // someone actually asks for one.
  driverName  String?
  driverPhone String?

  /// Capability token for the restaurant's OWN driver to stream live location from
  /// their phone, no login. Minted per self-delivery; the /d/<token> page posts GPS
  /// against it and we write it straight into courierLatitude/Longitude + a ping, so
  /// a self-rider's pin moves on the customer's map exactly like a courier's. Null
  /// for dispatched (Uber/DoorDash/Porter) deliveries — those report their own GPS.
  driverShareToken String? @unique

  /**
   * The courier's own identifiers, whichever courier that is. Interpret them
   * against `provider` above — a DoorDash delivery id means nothing to Uber's API,
   * and handing one to the wrong client is a confusing 404 rather than an error
   * that says what went wrong.
   *
   * These were `uberQuoteId` / `uberDeliveryId` until DoorDash Drive was added.
   * Renamed rather than duplicated: two nullable id columns where only one is ever
   * populated is a schema that invites reading the wrong one.
   */
  providerQuoteId    String?
  providerDeliveryId String? @unique
  trackingUrl        String?

  /// What the COURIER charges us for the delivery. May differ from what the customer
  /// paid (Order.deliveryFeeCents) — the difference is the restaurant's margin
  /// or subsidy, and the analytics page surfaces it.
  feeCents Int?
  currency String @default("USD")

  quoteExpiresAt DateTime?

  // Courier — populated from webhooks once assigned.
  courierName          String?
  courierPhone         String?
  courierVehicle       String?
  courierLatitude      Float?
  courierLongitude     Float?

  /**
   * Handoff identification.
   *
   * A busy kitchen at 8pm has three bags on the pass and two Uber couriers standing
   * at the counter. Handing the wrong bag to the wrong driver is the single most
   * common — and most expensive — operational failure in delivery: the food is gone,
   * both customers are furious, and neither order can be remade for free.
   *
   * So every delivery gets a short, human-readable code. It is printed on the bag
   * label AND sent to Uber as the manifest reference, which is what the courier
   * sees in their driver app. Staff ask "what's your code?", the driver reads it
   * off their phone, and it either matches the bag or it doesn't.
   *
   * Deliberately NOT the order number: order numbers are sequential and guessable,
   * and two orders in the same minute look almost identical on a bag label
   * (0712-014 vs 0712-041). A random 4-character code is unmistakable at a glance.
   */
  pickupCode       String?
  /// Set when staff confirm the code matched and the bag went out the door.
  handedOverAt     DateTime?
  handedOverByUserId String?

  pickupEta  DateTime?
  dropoffEta DateTime?

  pickedUpAt  DateTime?
  deliveredAt DateTime?
  cancelledAt DateTime?

  /// Proof-of-delivery photo the driver snaps when they hand the food over, from the
  /// /d/<token> page. A public storage URL; null until (and unless) they take one.
  proofOfDeliveryUrl String?

  /// Attempt counter for the retry queue. Guards against infinite retry loops.
  attemptCount Int      @default(0)
  lastError    String?
  lastAttemptAt DateTime?

  /**
   * When to try dispatching a courier again. NULL means nothing is pending.
   *
   * THIS COLUMN IS THE RETRY QUEUE. It used to be a Redis sorted set, which meant
   * the only record that an order still needed a courier lived in a cache — and a
   * Redis eviction, restart or flush silently forgot it. The order then sat there
   * with no courier and nothing anywhere to wake it up, which surfaces as a
   * customer phoning about food that never came.
   *
   * A queue whose loss is invisible is not a queue. So it lives in Postgres, next
   * to the delivery it belongs to, inside the same transaction that records the
   * failure. Redis is now only a cache and a lock, and losing it costs nothing but
   * a slow minute.
   */
  nextRetryAt DateTime?

  /**
   * How many times we have had to find a NEW courier for this order.
   *
   * Distinct from attemptCount, which counts failures to reach Uber at all. This
   * counts couriers who accepted and then vanished: Uber cancelled, the driver
   * un-assigned, the food was returned. Each one means a fresh delivery must be
   * created, and the customer's dinner is still sitting on the pass.
   *
   * Capped, because at some point the honest answer is "a human must deal with
   * this", not "let's ask Uber a seventh time".
   */
  redispatchCount Int @default(0)

  /**
   * Set when we gave up automating and put this in front of a human.
   *
   * An escalated delivery has NOT failed — it is still live, still owed to a
   * customer, and now loudly the restaurant's problem to solve (their own driver,
   * a phone call). The watchdog keeps it visible until someone resolves it.
   */
  escalatedAt     DateTime?
  escalationReason String?

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pings CourierPing[]

  @@index([restaurantId, status])
  /// The watchdog sweeps these every minute hunting for stranded orders.
  @@index([status, escalatedAt, updatedAt])
  /// The retry drain runs every 30 seconds and asks "what is due?". Without this,
  /// that question is a full scan of every delivery ever made, twice a minute.
  @@index([nextRetryAt])
  @@map("deliveries")
}

/// Courier breadcrumb trail.
///
/// `Delivery.courierLatitude/Longitude` holds only the LATEST position, which is
/// enough for a pin but not for a route. Keeping the trail lets the map draw the
/// path the driver actually took, which is what makes a tracking map feel live
/// rather than like a teleporting dot — and it lets us answer "where did the
/// driver go?" when a customer disputes a delivery.
///
/// Rows are only written when the courier has actually moved (see DeliveryService),
/// so a driver stuck at a traffic light doesn't generate 200 identical rows.
model CourierPing {
  id String @id @default(cuid())

  latitude  Float
  longitude Float

  deliveryId String
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([deliveryId, createdAt])
  @@map("courier_pings")
}

// ---------------------------------------------------------------------------
// QR codes
// ---------------------------------------------------------------------------

model QRCode {
  id    String     @id @default(cuid())
  type  QRCodeType
  label String

  /// Only meaningful for TABLE codes. Pre-fills the order's table number.
  tableNumber String?

  /// The encoded URL, e.g. https://joes.dinedirect.manvion.ca/menu?src=qr&c=<id>
  targetUrl String
  /// Azure Blob URL of the rendered PNG.
  imageUrl  String?

  /// Incremented on every storefront hit carrying this code's id.
  scanCount Int      @default(0)
  lastScanAt DateTime?

  isActive Boolean @default(true)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@index([restaurantId, type])
  @@map("qr_codes")
}

// ---------------------------------------------------------------------------
// Platform infrastructure
// ---------------------------------------------------------------------------

/// Who did what. Written for every mutating staff action and every inbound
/// webhook that changes state.
model AuditLog {
  id String @id @default(cuid())

  /// e.g. "order.accepted", "menu.product.deleted", "payment.refunded"
  action String
  /// e.g. "Order", "Product"
  entityType String
  entityId   String?

  /// Before/after snapshot for mutations. Redacted of PII where applicable.
  metadata Json?

  ipAddress String?
  userAgent String?

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  /// Null when the actor is a webhook or a background job rather than a person.
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([restaurantId, createdAt])
  @@index([restaurantId, entityType, entityId])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Notifications
// ---------------------------------------------------------------------------

enum NotificationChannel {
  SMS
  EMAIL
}

/// Who the message was for. The same order event produces different messages for
/// the two audiences: the customer wants "your food is on its way", the kitchen
/// wants "table 4, two burgers, no pickles".
enum NotificationAudience {
  CUSTOMER
  RESTAURANT
}

enum NotificationStatus {
  SENT
  FAILED
  /// Deliberately not sent — customer replied STOP, or the restaurant turned this
  /// channel off. Recorded so support can answer "why didn't I get a text?".
  SKIPPED
}

/// Every message we attempted, and what happened to it.
///
/// This exists because "the customer says they never got the text" is the single
/// most common support ticket in food delivery, and without a log the honest
/// answer is a shrug.
model NotificationLog {
  id String @id @default(cuid())

  channel  NotificationChannel
  audience NotificationAudience
  status   NotificationStatus

  /// e.g. "order.accepted", "order.delivered.thank_you", "restaurant.new_order"
  template String

  /// Masked at write time — we keep "***0188", never the full number. A log of
  /// every customer's phone number is a breach waiting to happen.
  recipient String

  /// Twilio SID / Resend id, for tracing a message into the provider's dashboard.
  providerId String?
  error      String?

  orderId String?

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([restaurantId, createdAt])
  @@index([orderId])
  @@map("notification_logs")
}

// ---------------------------------------------------------------------------
// Staff invitations
// ---------------------------------------------------------------------------

/// An invitation to join a restaurant's staff.
///
/// Without this there is no way to add a second person to a restaurant — the only
/// User row that ever gets created is the founder's. The invited person may not
/// have a Clerk account yet, which is why the invite is keyed by email and only
/// becomes a User when they accept.
model StaffInvite {
  id String @id @default(cuid())

  email String
  role  StaffRole @default(STAFF)

  /// Unguessable. It is the whole authorisation for accepting — the accept link we
  /// email must not be walkable to someone else's invite.
  token String @unique @default(cuid())

  /// Invites rot. A link that still works six months later is a way into a
  /// restaurant's orders long after the person was meant to join.
  expiresAt DateTime

  acceptedAt DateTime?
  revokedAt  DateTime?

  invitedByUserId String?

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  /// One live invite per email per restaurant.
  @@unique([restaurantId, email])
  @@index([token])
  @@map("staff_invites")
}

// ---------------------------------------------------------------------------
// Website integration (embeddable widget)
// ---------------------------------------------------------------------------

/// One integration per restaurant website. A restaurant with a WordPress site and
/// a separate landing page has two, so revenue can be attributed to each.
model WebsiteIntegration {
  id String @id @default(cuid())

  /// Human label, e.g. "Main site (WordPress)".
  name String

  /// The primary domain, normalised to a bare host: "joes.com", never "https://joes.com/".
  domain String

  /// PUBLIC identifier, embedded in the customer's HTML. Deliberately NOT a secret —
  /// anyone can read it by viewing source, so it must not be treated as one.
  /// Authorisation comes from `allowedDomains` + the Origin header, not from
  /// possession of this key. Prefixed so it is greppable in logs and support tickets.
  widgetKey String @unique

  /// Every host permitted to embed this widget. An Origin not on this list is
  /// refused at the CORS layer AND at the guard, so a scraped widgetKey pasted
  /// into another site simply does not work.
  allowedDomains String[]

  /// Appearance + behaviour. See WidgetSettings in packages/shared.
  settings Json

  isActive Boolean @default(true)

  /// Set the first time a real browser loads the widget from an allowed origin.
  /// The dashboard uses it to say "we haven't seen this on your site yet",
  /// which is the single most useful piece of install debugging we can offer.
  installedAt   DateTime?
  lastSeenAt    DateTime?

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events WidgetEvent[]
  orders Order[]

  @@index([restaurantId])
  @@map("website_integrations")
}

enum WidgetEventType {
  /// The loader script ran and the button rendered. The denominator for conversion.
  VIEW
  /// The customer clicked "Order Now" and the widget opened.
  OPEN
  ADD_TO_CART
  CHECKOUT_START
  /// An order row was created. Payment may still fail — revenue is read from
  /// Order/Payment, never from this table.
  ORDER_CREATED
}

/// Widget funnel telemetry. Deliberately thin: no cookies, no cross-site
/// identifiers, no PII — a random per-visit sessionId is enough to compute a
/// funnel, and anything more would make this a tracker we'd have to disclose.
model WidgetEvent {
  type WidgetEventType

  id String @id @default(cuid())

  /// Random, generated in the browser per visit. Lets us count unique visitors
  /// through the funnel without identifying anyone.
  sessionId String

  /// The Origin the event came from. Recorded because a restaurant with several
  /// domains wants revenue split by site, not summed.
  origin String?

  /// Populated on ORDER_CREATED so the funnel can be joined to real money.
  orderId String?

  integrationId String
  integration   WebsiteIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([integrationId, type, createdAt])
  @@index([restaurantId, createdAt])
  /// One row per session per event type: a customer who opens the widget five
  /// times is one "open", or the conversion rate becomes meaningless.
  @@unique([integrationId, sessionId, type])
  @@map("widget_events")
}

/// Idempotency ledger for inbound webhooks. Stripe and Uber both retry, and
/// both can deliver out of order — we insert the provider's event id here first
/// and skip anything we've already processed.
model WebhookEvent {
  id String @id @default(cuid())

  /// "stripe" | "uber"
  provider String
  /// The provider's own event id — the uniqueness key that makes retries safe.
  eventId  String
  eventType String

  payload Json

  processedAt DateTime?
  error       String?
  attempts    Int       @default(0)

  createdAt DateTime @default(now())

  @@unique([provider, eventId])
  @@index([provider, processedAt])
  @@map("webhook_events")
}

// ---------------------------------------------------------------------------
// Catering & parties (Growth/Pro capability CATERING)
//
// Two shapes of demand a restaurant gets that ordinary menu ordering doesn't serve:
//   1. A fixed PACKAGE priced per head — "the taco bar, $18/person, min 15" — which
//      a customer sizes to their headcount and pays for online, in full, up front.
//   2. A CUSTOM job that needs a conversation — "wedding, 120 people, dietary
//      needs" — which is a lead, not a checkout: captured with an event date and
//      contact details for the restaurant to quote.
// Both land in the same admin inbox (CateringRequest); only PACKAGE carries a price
// and a payment.
// ---------------------------------------------------------------------------

/// A per-head catering package the restaurant offers. The customer multiplies it by
/// their headcount at checkout; the total is (pricePerPersonCents * people).
model CateringPackage {
  id           String  @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  name        String
  description String?
  imageUrl    String?

  pricePerPersonCents Int
  /// The smallest party this package is offered for — catering has a floor below
  /// which it isn't worth the kitchen's while. Enforced at checkout.
  minPeople   Int  @default(10)
  /// Optional ceiling; null = no upper limit.
  maxPeople   Int?

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  requests  CateringRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId, isActive, sortOrder])
  @@map("catering_packages")
}

enum CateringType {
  PACKAGE
  CUSTOM
}

enum CateringStatus {
  /// Just came in — needs the restaurant's attention.
  NEW
  /// The restaurant has acknowledged / is quoting or preparing it.
  IN_PROGRESS
  /// Agreed and (for PACKAGE) paid.
  CONFIRMED
  /// Event done.
  COMPLETED
  CANCELLED
}

/// One catering enquiry OR paid package order. The admin inbox for parties.
model CateringRequest {
  id           String  @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  type   CateringType
  status CateringStatus @default(NEW)

  // Who's asking.
  customerName  String
  customerEmail String
  customerPhone String

  // The party.
  headCount   Int
  /// The date the food is needed. A date picker on the storefront; time-of-day and
  /// finer detail go in `message`.
  eventDate   DateTime
  fulfillment FulfillmentType @default(PICKUP)
  /// Free-text delivery address (catering skips the geocoded-address machinery of
  /// normal delivery — the restaurant reads it and decides). Null for pickup.
  deliveryAddress String?
  /// Anything else: dietary needs, timing, the whole custom brief.
  message     String?

  // PACKAGE only. Frozen at request time so a later price change never rewrites
  // what the customer agreed to.
  packageId           String?
  package             CateringPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  packageName         String?
  pricePerPersonCents Int?
  totalCents          Int?

  // Payment (PACKAGE only). Mirrors the light footprint on Payment: which provider,
  // its reference, and when it cleared. CUSTOM requests carry none of this.
  paymentStatus     PaymentStatus @default(PENDING)
  paymentProvider   String?
  stripeSessionId   String?
  razorpayOrderId   String?
  paidAt            DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId, status, createdAt])
  @@index([stripeSessionId])
  @@map("catering_requests")
}

enum ReservationStatus {
  /// Booked and holding a slot. Auto-confirmed when capacity allowed it.
  CONFIRMED
  /// Party arrived and was seated.
  SEATED
  /// Visit finished.
  COMPLETED
  /// Called off — by the customer or the restaurant. Frees the slot.
  CANCELLED
  /// Booked, never showed. Kept distinct from CANCELLED for the restaurant's own record.
  NO_SHOW
}

/// One table booking. "Simple capacity per slot": a slot is available while the count
/// of live (CONFIRMED/SEATED) reservations at that exact start time is below the
/// restaurant's reservationCapacityPerSlot. No per-table assignment — that's a
/// deliberately larger feature the restaurant can grow into later.
model Reservation {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  status ReservationStatus @default(CONFIRMED)

  // Who's booking.
  customerName  String
  customerPhone String
  customerEmail String?

  partySize Int
  /// The slot start. Stored in UTC; rendered in the restaurant's timezone.
  reservedAt DateTime
  /// Anything else: a birthday, a highchair, a dietary need.
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The availability query counts live bookings for a restaurant in a time range,
  // so restaurant + time is the hot index.
  @@index([restaurantId, reservedAt])
  @@index([restaurantId, status, reservedAt])
  @@map("reservations")
}
